import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import java.util.ListIterator;
import java.util.Spliterator;

// Custom class that extends ArrayList to allow demonstrating the protected 'removeRange' method
public class ArrayListAllMethods extends ArrayList<String> {

    public static void main(String[] args) {
        System.out.println("=== STARTING ARRAYLIST METHOD DEMONSTRATIONS ===");
        
        runAddAtIndex();
        runAddElement();
        runAddAll();
        runAddAllAtIndex();
        runClear();
        runClone();
        runContains();
        runEnsureCapacity();
        runForEach();
        runGet();
        runIndexOf();
        runIsEmpty();
        runLastIndexOf();
        runListIterator();
        runListIteratorAtIndex();
        runRemoveAtIndex();
        runRemoveObject();
        runRemoveAll();
        runRemoveIf();
        runRemoveRange();
        runRetainAll();
        runSet();
        runSize();
        runSpliterator();
        runSubList();
        runToArray();
        runToArrayTyped();
        runTrimToSize();

        System.out.println("\n=== ALL DEMONSTRATIONS COMPLETED ===");
    }

    // 1. add(int index, Object element)
    public static void runAddAtIndex() {
        System.out.println("\n--- 1. add(int index, Object element) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add(1, "Cherry"); // Inserts at index 1
        System.out.println(list); 
    }

    // 2. add(Object o)
    public static void runAddElement() {
        System.out.println("\n--- 2. add(Object o) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        System.out.println(list); 
    }

    // 3. addAll(Collection C)
    public static void runAddAll() {
        System.out.println("\n--- 3. addAll(Collection C) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        List<String> news = Arrays.asList("Banana", "Cherry");
        list.addAll(news);
        System.out.println(list); 
    }

    // 4. addAll(int index, Collection C)
    public static void runAddAllAtIndex() {
        System.out.println("\n--- 4. addAll(int index, Collection C) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Date");
        List<String> news = Arrays.asList("Banana", "Cherry");
        list.addAll(1, news);
        System.out.println(list); 
    }

    // 5. clear()
    public static void runClear() {
        System.out.println("\n--- 5. clear() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.clear();
        System.out.println("List after clear(): " + list); 
    }

    // 6. clone()
    @SuppressWarnings("unchecked")
    public static void runClone() {
        System.out.println("\n--- 6. clone() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        ArrayList<String> copy = (ArrayList<String>) list.clone();
        System.out.println("Cloned List: " + copy); 
    }

    // 7. contains(Object o)
    public static void runContains() {
        System.out.println("\n--- 7. contains(Object o) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        System.out.println("Contains 'Apple'? " + list.contains("Apple"));  
        System.out.println("Contains 'Banana'? " + list.contains("Banana")); 
    }

    // 8. ensureCapacity(int minCapacity)
    public static void runEnsureCapacity() {
        System.out.println("\n--- 8. ensureCapacity(int minCapacity) ---");
        ArrayList<String> list = new ArrayList<>();
        list.ensureCapacity(500); 
        System.out.println("Capacity optimization complete.");
    }

    // 9. forEach(Consumer<? super E> action)
    public static void runForEach() {
        System.out.println("\n--- 9. forEach(Consumer<? super E> action) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.forEach(fruit -> System.out.println("Processing: " + fruit));
    }

    // 10. get(int index)
    public static void runGet() {
        System.out.println("\n--- 10. get(int index) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        System.out.println("Element at index 1: " + list.get(1)); 
    }

    // 11. indexOf(Object o)
    public static void runIndexOf() {
        System.out.println("\n--- 11. indexOf(Object o) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Apple");
        System.out.println("First index of 'Apple': " + list.indexOf("Apple")); 
    }

    // 12. isEmpty()
    public static void runIsEmpty() {
        System.out.println("\n--- 12. isEmpty() ---");
        ArrayList<String> list = new ArrayList<>();
        System.out.println("Is empty initially? " + list.isEmpty()); 
        list.add("Apple");
        System.out.println("Is empty after adding? " + list.isEmpty()); 
    }

    // 13. lastIndexOf(Object O)
    public static void runLastIndexOf() {
        System.out.println("\n--- 13. lastIndexOf(Object O) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Apple");
        System.out.println("Last index of 'Apple': " + list.lastIndexOf("Apple")); 
    }

    // 14. listIterator()
    public static void runListIterator() {
        System.out.println("\n--- 14. listIterator() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        ListIterator<String> litr = list.listIterator();
        while(litr.hasNext()) {
            System.out.println("Iterator item: " + litr.next());
        }
    }

    // 15. listIterator(int index)
    public static void runListIteratorAtIndex() {
        System.out.println("\n--- 15. listIterator(int index) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Cherry");
        ListIterator<String> litr = list.listIterator(1); // Start from 'Banana'
        while(litr.hasNext()) {
            System.out.println("Iterator from index 1: " + litr.next()); 
        }
    }

    // 16. remove(int index)
    public static void runRemoveAtIndex() {
        System.out.println("\n--- 16. remove(int index) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.remove(0); 
        System.out.println("After removing index 0: " + list); 
    }

    // 17. remove(Object o)
    public static void runRemoveObject() {
        System.out.println("\n--- 17. remove(Object o) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.remove("Apple");
        System.out.println("After removing 'Apple': " + list); 
    }

    // 18. removeAll(Collection c)
    public static void runRemoveAll() {
        System.out.println("\n--- 18. removeAll(Collection c) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Apple");
        list.add("Cherry");
        list.removeAll(Arrays.asList("Apple", "Cherry"));
        System.out.println("After removeAll: " + list); 
    }

    // 19. removeIf(Predicate filter)
    public static void runRemoveIf() {
        System.out.println("\n--- 19. removeIf(Predicate filter) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Apricot");
        list.removeIf(fruit -> fruit.startsWith("A"));
        System.out.println("After removeIf (starts with 'A'): " + list); 
    }

    // 20. removeRange(int fromIndex, int toIndex)
    public static void runRemoveRange() {
        System.out.println("\n--- 20. removeRange(int fromIndex, int toIndex) ---");
        // Creating an instance of our own class because removeRange is a protected method
        ArrayListAllMethods customList = new ArrayListAllMethods();
        customList.add("A");
        customList.add("B");
        customList.add("C");
        customList.add("D");
        customList.removeRange(1, 3); // Removes indexes 1 and 2
        System.out.println("After removeRange(1, 3): " + customList); 
    }

    // 21. retainAll(Collection<?> c)
    public static void runRetainAll() {
        System.out.println("\n--- 21. retainAll(Collection<?> c) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Cherry");
        list.retainAll(Arrays.asList("Banana", "Cherry", "Date"));
        System.out.println("After retainAll: " + list); 
    }

    // 22. set(int index, E element)
    public static void runSet() {
        System.out.println("\n--- 22. set(int index, E element) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.set(1, "Cherry"); 
        System.out.println("After set(1, 'Cherry'): " + list); 
    }

    // 23. size()
    public static void runSize() {
        System.out.println("\n--- 23. size() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        System.out.println("List size: " + list.size()); 
    }

    // 24. spliterator()
    public static void runSpliterator() {
        System.out.println("\n--- 24. spliterator() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        Spliterator<String> splitr = list.spliterator();
        System.out.print("Spliterator output: ");
        splitr.forEachRemaining(fruit -> System.out.print(fruit + " "));
        System.out.println();
    }

    // 25. subList(int fromIndex, int toIndex)
    public static void runSubList() {
        System.out.println("\n--- 25. subList(int fromIndex, int toIndex) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("A");
        list.add("B");
        list.add("C");
        list.add("D");
        List<String> sub = list.subList(1, 3);
        System.out.println("SubList view (1 to 3): " + sub); 
    }

    // 26. toArray()
    public static void runToArray() {
        System.out.println("\n--- 26. toArray() ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        Object[] array = list.toArray();
        System.out.println("Array item 0: " + array[0]); 
    }

    // 27. toArray(Object[] O)
    public static void runToArrayTyped() {
        System.out.println("\n--- 27. toArray(Object[] O) ---");
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        String[] array = list.toArray(new String[0]);
        System.out.println("Typed Array item 0: " + array[0]); 
    }

    // 28. trimToSize()
    public static void runTrimToSize() {
        System.out.println("\n--- 28. trimToSize() ---");
        ArrayList<String> list = new ArrayList<>(100); 
        list.add("Apple");
        list.add("Banana");
        list.trimToSize(); 
        System.out.println("Internal capacity successfully trimmed down.");
    }
}
